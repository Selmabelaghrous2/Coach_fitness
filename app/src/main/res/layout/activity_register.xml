<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@color/surface_variant"
                android:backgroundTint="@color/surface_variant"
                android:tint="@color/on_surface"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:text="Créer un compte"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Card formulaire -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Email"
                    app:boxBackgroundColor="@color/surface_variant"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/on_surface_secondary"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/on_surface_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Mot de passe -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Mot de passe"
                    app:boxBackgroundColor="@color/surface_variant"
                    app:boxStrokeColor="@color/primary"
                    app:endIconMode="password_toggle"
                    app:hintTextColor="@color/on_surface_secondary"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/on_surface_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Niveau -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Niveau de forme"
                    android:textColor="@color/on_surface_secondary"
                    android:textSize="13sp" />

                <!-- Chips niveau -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBeginner"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Débutant"
                        android:textColor="@color/on_surface"
                        app:checkedIconTint="@color/primary"
                        app:chipBackgroundColor="@color/surface_variant" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipIntermediate"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intermédiaire"
                        android:textColor="@color/on_surface"
                        app:checkedIconTint="@color/primary"
                        app:chipBackgroundColor="@color/surface_variant" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAdvanced"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avancé"
                        android:textColor="@color/on_surface"
                        app:checkedIconTint="@color/primary"
                        app:chipBackgroundColor="@color/surface_variant" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:text="CRÉER MON COMPTE"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Déjà inscrit ? "
                        android:textColor="@color/on_surface_secondary" />

                    <TextView
                        android:id="@+id/tvLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Se connecter"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>